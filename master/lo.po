#: libdnf/dnf-transaction.cpp:1196
msgid "failed to set root"
msgstr "ກຳນົດ root ບໍ່ສຳເລັດ"

#: libdnf/dnf-transaction.cpp:1418
#, c-format
msgid "Error %i running transaction test"
msgstr "ເກີດຂໍ້ຜິດພາດ %i ໃນການທົດສອບທຸລະກຳ"

#: libdnf/dnf-transaction.cpp:1458
#, c-format
msgid "Error %i running transaction"
msgstr "ເກີດຂໍ້ຜິດພາດ %i ໃນການດຳເນີນການທຸລະກຳ"

