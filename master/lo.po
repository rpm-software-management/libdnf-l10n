msgstr "ເປີດບໍ່ສຳເລັດ (ຂໍ້ຜິດພາດທົ່ວໄປ): %s"

#: libdnf/dnf-rpmts.cpp:142
#, c-format
msgid "failed to verify key for %s"
msgstr "ຢືນຢັນຄີ (key) ສຳລັບ %s ບໍ່ສຳເລັດ"

#: libdnf/dnf-rpmts.cpp:150
#, c-format
msgid "public key unavailable for %s"
msgstr "ບໍ່ມີຄີສາທາລະນະສຳລັບ %s"

#: libdnf/dnf-rpmts.cpp:158
#, c-format
msgid "signature not found for %s"
msgstr "ບໍ່ພົບລາຍເຊັນສຳລັບ %s"

#: libdnf/dnf-rpmts.cpp:193
#, c-format
msgid "failed to add install element: %1$s [%2$i]"
msgstr "ເພີ່ມອົງປະກອບການຕິດຕັ້ງບໍ່ສຳເລັດ: %1$s [%2$i]"

#: libdnf/dnf-rpmts.cpp:274
#, c-format
msgid "Error running transaction: %s"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການດຳເນີນການທຸລະກຳ: %s"

#: libdnf/dnf-rpmts.cpp:283
msgid "Error running transaction and no problems were reported!"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການດຳເນີນການທຸລະກຳ ແລະ ບໍ່ມີການລາຍງານບັນຫາໃດໆ!"

#: libdnf/dnf-rpmts.cpp:346
msgid "Fatal error, run database recovery"
