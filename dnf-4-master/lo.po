#: libdnf/conf/ConfigMain.cpp:62 libdnf/conf/OptionSeconds.cpp:40
msgid "no value specified"
msgstr "ບໍ່ໄດ້ລະບຸຄ່າ"

#: libdnf/conf/ConfigMain.cpp:67 libdnf/conf/OptionSeconds.cpp:48
#, c-format
msgid "seconds value '%s' must not be negative"
msgstr "ຄ່າວິນາທີ '%s' ຕ້ອງບໍ່ເປັນຄ່າລົບ"

#: libdnf/conf/ConfigMain.cpp:71
#, c-format
msgid "could not convert '%s' to bytes"
msgstr "ບໍ່ສາມາດແປງ '%s' ເປັນໄບຕ໌ (bytes)"

#: libdnf/conf/ConfigMain.cpp:83 libdnf/conf/OptionSeconds.cpp:66
#, c-format
msgid "unknown unit '%s'"
msgstr "ບໍ່ຮູ້ຈັກຫົວໜ່ວຍ '%s'"

#: libdnf/conf/ConfigMain.cpp:205 libdnf/conf/OptionEnum.cpp:83
#: libdnf/conf/OptionNumber.cpp:88
msgid "invalid value"
msgstr "ຄ່າບໍ່ຖືກຕ້ອງ"

#: libdnf/conf/ConfigMain.cpp:208
msgid "value 1 is not allowed"
msgstr "ບໍ່ອະນຸຍາດໃຫ້ໃຊ້ຄ່າ 1"

#: libdnf/conf/ConfigMain.cpp:210
msgid "negative value is not allowed"
msgstr "ບໍ່ອະນຸຍາດໃຫ້ໃຊ້ຄ່າລົບ"

#: libdnf/conf/ConfigMain.cpp:348
#, c-format
msgid "percentage '%s' is out of range"
msgstr "ເປີເຊັນ '%s' ຢູ່ນອກຂອບເຂດ"

#: libdnf/conf/OptionBinds.cpp:85
#, c-format
msgid "Configuration: OptionBinding with id \"%s\" does not exist"
msgstr "ການຕັ້ງຄ່າ: ບໍ່ມີ OptionBinding ທີ່ມີ id \"%s\""

#: libdnf/conf/OptionBinds.cpp:97
#, c-format
msgid "Configuration: OptionBinding with id \"%s\" already exists"
msgstr "ການຕັ້ງຄ່າ: ມີ OptionBinding ທີ່ມີ id \"%s\" ຢູ່ແລ້ວ"

#: libdnf/conf/OptionBool.cpp:47
#, c-format
msgid "invalid boolean value '%s'"
msgstr "ຄ່າບູລີນ (boolean) '%s' ບໍ່ຖືກຕ້ອງ"

#: libdnf/conf/OptionEnum.cpp:72 libdnf/conf/OptionEnum.cpp:158
#: libdnf/conf/OptionString.cpp:64 libdnf/conf/OptionStringList.cpp:59
#, c-format
msgid "'%s' is not an allowed value"
msgstr "'%s' ບໍ່ແມ່ນຄ່າທີ່ອະນຸຍາດໃຫ້ໃຊ້"

#: libdnf/conf/OptionNumber.cpp:73
#, c-format
msgid "given value [%d] should be less than allowed value [%d]."
msgstr "ຄ່າທີ່ລະບຸ [%d] ຄວນຈະໜ້ອຍກວ່າຄ່າທີ່ອະນຸຍາດ [%d]."

#: libdnf/conf/OptionNumber.cpp:76
#, c-format
msgid "given value [%d] should be greater than allowed value [%d]."
msgstr "ຄ່າທີ່ລະບຸ [%d] ຄວນຈະຫຼາຍກວ່າຄ່າທີ່ອະນຸຍາດ [%d]."

#: libdnf/conf/OptionPath.cpp:78
#, c-format
msgid "given path '%s' is not absolute."
msgstr "ເສັ້ນທາງ '%s' ທີ່ລະບຸ ບໍ່ແມ່ນເສັ້ນທາງສົມບູນ (absolute path)."

#: libdnf/conf/OptionPath.cpp:82
#, c-format
msgid "given path '%s' does not exist."
msgstr "ບໍ່ມີເສັ້ນທາງ '%s' ທີ່ລະບຸຢູ່."

#: libdnf/conf/OptionSeconds.cpp:52
#, c-format
msgid "could not convert '%s' to seconds"
msgstr "ບໍ່ສາມາດແປງ '%s' ເປັນວິນາທີ"

#: libdnf/conf/OptionString.cpp:79
msgid "GetValue(): Value not set"
msgstr "GetValue(): ບໍ່ໄດ້ຕັ້ງຄ່າໄວ້"

#: libdnf/dnf-context.cpp:3326 libdnf/dnf-context.cpp:3335
#, c-format
msgid "Cannot enable more streams from module '%s' at the same time"
msgstr "ບໍ່ສາມາດເປີດໃຊ້ຫຼາຍສະຕຣີມຈາກໂມດູນ '%s' ໃນເວລາດຽວກັນໄດ້"

#: libdnf/dnf-context.cpp:3344 libdnf/dnf-context.cpp:3362
#, c-format
msgid ""
"Cannot enable module '%1$s' stream '%2$s': State of module already modified"
msgstr ""
"ບໍ່ສາມາດເປີດໃຊ້ໂມດູນ '%1$s' ສະຕຣີມ '%2$s': ສະຖານະຂອງໂມດູນຖືກປ່ຽນແປງໄປແລ້ວ"

#: libdnf/dnf-context.cpp:3411
#, c-format
msgid "Modular dependency problem with Defaults: %s"
msgstr "ບັນຫາຄວາມກ່ຽວພັນຂອງໂມດູນກັບຄ່າເລີ່ມຕົ້ນ: %s"

#: libdnf/dnf-context.cpp:3414
#, c-format
msgid "Modular dependency problem with the latest modules: %s"
msgstr "ບັນຫາຄວາມກ່ຽວພັນຂອງໂມດູນກັບໂມດູນລຸ້ນຫຼ້າສຸດ: %s"

#: libdnf/dnf-context.cpp:3418
#, c-format
msgid "Modular dependency problem: %s"
msgstr "ບັນຫາຄວາມກ່ຽວພັນຂອງໂມດູນ: %s"

#: libdnf/dnf-context.cpp:3441 libdnf/dnf-context.cpp:3465
#: libdnf/dnf-context.cpp:3476 libdnf/dnf-context.cpp:3515
#: libdnf/dnf-context.cpp:3531 libdnf/dnf-context.cpp:3563
#: libdnf/dnf-context.cpp:3612 libdnf/dnf-context.cpp:3622
#, c-format
msgid "Unable to resolve argument '%s'"
msgstr "ບໍ່ສາມາດແກ້ໄຂອາຄິວເມັນ (argument) '%s'"

#: libdnf/dnf-context.cpp:3448
#, c-format
msgid ""
"Only module name is required. Ignoring unneeded information in argument: '%s'"
msgstr ""
"ຕ້ອງການພຽງແຕ່ຊື່ໂມດູນເທົ່ານັ້ນ. ຈະບໍ່ສົນໃຈຂໍ້ມູນທີ່ບໍ່ຈຳເປັນໃນອາຄິວເມັນ: '%s'"

#: libdnf/dnf-context.cpp:3462
#, c-format
msgid "Cannot reset module '%s': State of module already modified"
msgstr "ບໍ່ສາມາດຄືນຄ່າ (reset) ໂມດູນ '%s': ສະຖານະຂອງໂມດູນຖືກປ່ຽນແປງໄປແລ້ວ"

#: libdnf/dnf-context.cpp:3473
#, c-format
msgid "Cannot disable module '%s': State of module already modified"
msgstr "ບໍ່ສາມາດປິດໃຊ້ໂມດູນ '%s': ສະຖານະຂອງໂມດູນຖືກປ່ຽນແປງໄປແລ້ວ"

#: libdnf/dnf-context.cpp:3504 libdnf/dnf-context.cpp:3600
#: libdnf/dnf-context.cpp:3781
msgid "No modular data available"
msgstr "ບໍ່ມີຂໍ້ມູນໂມດູນ"

#: libdnf/dnf-context.cpp:3521
#, c-format
msgid "Ignoring unneeded information in argument: '%s'"
msgstr "ຈະບໍ່ສົນໃຈຂໍ້ມູນທີ່ບໍ່ຈຳເປັນໃນອາຄິວເມັນ: '%s'"

#: libdnf/dnf-context.cpp:3559
#, c-format
msgid ""
"Problem during enablement of dependency tree for module '%1$s' stream "
"'%2$s': %3$s"
msgstr ""
"ເກີດບັນຫາລະຫວ່າງການເປີດໃຊ້ໂຄງສ້າງຄວາມກ່ຽວພັນສຳລັບໂມດູນ '%1$s' ສະຕຣີມ '%2$s': %3$s"

#: libdnf/dnf-context.cpp:3571
msgid "Problems appeared for module enable request:"
msgstr "ເກີດບັນຫາໃນການຮ້ອງຂໍເປີດໃຊ້ໂມດູນ:"

#: libdnf/dnf-context.cpp:3666
#, c-format
msgid "No active module packages found for module spec '%s'"
msgstr "ບໍ່ພົບແພັກເກດໂມດູນທີ່ເຮັດວຽກຢູ່ສຳລັບຂໍ້ກຳນົດໂມດູນ '%s'"

#: libdnf/dnf-context.cpp:3671
#, c-format
msgid "Cannot install module '%s' from fail-safe repository"
msgstr "ບໍ່ສາມາດຕິດຕັ້ງໂມດູນ '%s' ຈາກຄັງເກັບແບບ fail-safe ໄດ້"

#: libdnf/dnf-context.cpp:3678
#, c-format
msgid "No profile found matching '%s'"
msgstr "ບໍ່ພົບໂປຣໄຟລ໌ທີ່ກົງກັບ '%s'"

#: libdnf/dnf-context.cpp:3732
#, c-format
msgid "No match for package '%s' for module spec %s"
msgstr "ບໍ່ມີແພັກເກດທີ່ກົງກັບ '%s' ສຳລັບຂໍ້ກຳນົດໂມດູນ %s"

#: libdnf/dnf-context.cpp:3743
#, c-format
msgid "Problem during install for module '%1$s' stream '%2$s': %3$s"
msgstr "ເກີດບັນຫາລະຫວ່າງການຕິດຕັ້ງໂມດູນ '%1$s' ສະຕຣີມ '%2$s': %3$s"

#: libdnf/dnf-context.cpp:3752
msgid "Problems appeared for module install request:"
msgstr "ເກີດບັນຫາໃນການຮ້ອງຂໍຕິດຕັ້ງໂມດູນ:"

#: libdnf/dnf-context.cpp:3811
msgid "Problems appeared for module reset request:"
msgstr "ເກີດບັນຫາໃນການຮ້ອງຂໍຄືນຄ່າໂມດູນ:"

#: libdnf/dnf-context.cpp:3812 libdnf/dnf-context.cpp:3871
msgid "Problems appeared for module disable request:"
msgstr "ເກີດບັນຫາໃນການຮ້ອງຂໍປິດໃຊ້ໂມດູນ:"

#: libdnf/dnf-context.cpp:3903
#, c-format
msgid ""
"The operation would result in switching of module '%s' stream '%s' to stream "
"'%s'"
msgstr ""
"ການດຳເນີນການນີ້ຈະເຮັດໃຫ້ມີການປ່ຽນສະຕຣີມຂອງໂມດູນ '%s' ຈາກ '%s' ໄປເປັນ '%s'"

#: libdnf/dnf-context.cpp:3907
msgid ""
"It is not possible to switch enabled streams of a module.\n"
"It is recommended to remove all installed content from the module, and reset "
"the module using 'microdnf module reset <module_name>' command. After you "
"reset the module, you can install the other stream."
msgstr ""
"ບໍ່ສາມາດປ່ຽນສະຕຣີມທີ່ເປີດໃຊ້ຢູ່ຂອງໂມດູນໄດ້.\n"
"ແນະນຳໃຫ້ລຶບເນື້ອຫາທີ່ຕິດຕັ້ງທັງໝົດອອກຈາກໂມດູນ, ແລ້ວຄືນຄ່າໂມດູນໂດຍໃຊ້ຄຳສັ່ງ 'microdnf module "
"reset <module_name>'. ຫຼັງຈາກຄືນຄ່າໂມດູນແລ້ວ, ທ່ານຈຶ່ງຈະສາມາດຕິດຕັ້ງສະຕຣີມອື່ນໄດ້."

#: libdnf/dnf-goal.cpp:107
msgid "Could not depsolve transaction; "
msgstr "ບໍ່ສາມາດແກ້ໄຂຄວາມກ່ຽວພັນຂອງທຸລະກຳໄດ້; "

#: libdnf/dnf-goal.cpp:109
#, c-format
msgid "%i problem detected:\n"
msgid_plural "%i problems detected:\n"
msgstr[0] "ກວດພົບ %i ບັນຫາ:\n"

#: libdnf/dnf-goal.cpp:117
#, c-format
msgid " Problem %1$i: %2$s\n"
msgstr " ບັນຫາ %1$i: %2$s\n"

#: libdnf/dnf-goal.cpp:119
#, c-format
msgid " Problem: %s\n"
msgstr " ບັນຫາ: %s\n"

#: libdnf/dnf-rpmts.cpp:79
#, c-format
msgid ""
"No available modular metadata for modular package '%s'; cannot be installed "
"on the system"
msgstr ""
"ບໍ່ມີຂໍ້ມູນເມຕາເດຕາໂມດູນສຳລັບແພັກເກດໂມດູນ '%s'; ບໍ່ສາມາດຕິດຕັ້ງໃນລະບົບໄດ້"

#: libdnf/dnf-rpmts.cpp:105 libdnf/dnf-rpmts.cpp:145
#, c-format
msgid "signature does not verify for %s"
msgstr "ລາຍເຊັນຂອງ %s ບໍ່ໄດ້ຮັບການຢືນຢັນ"

#: libdnf/dnf-rpmts.cpp:112 libdnf/dnf-rpmts.cpp:152
#, c-format
msgid "failed to open(generic error): %s"
msgstr "ເປີດບໍ່ສຳເລັດ (ຂໍ້ຜິດພາດທົ່ວໄປ): %s"

#: libdnf/dnf-rpmts.cpp:124
#, c-format
msgid "failed to verify key for %s"
msgstr "ຢືນຢັນຄີ (key) ສຳລັບ %s ບໍ່ສຳເລັດ"

#: libdnf/dnf-rpmts.cpp:131
#, c-format
msgid "public key unavailable for %s"
msgstr "ບໍ່ມີຄີສາທາລະນະສຳລັບ %s"

#: libdnf/dnf-rpmts.cpp:138
#, c-format
msgid "signature not found for %s"
msgstr "ບໍ່ພົບລາຍເຊັນສຳລັບ %s"

#: libdnf/dnf-rpmts.cpp:186
#, c-format
msgid "failed to add reinstall element: %1$s [%2$i]"
msgstr "ເພີ່ມອົງປະກອບການຕິດຕັ້ງໃໝ່ບໍ່ສຳເລັດ: %1$s [%2$i]"

#: libdnf/dnf-rpmts.cpp:231
#, c-format
msgid "failed to add install element: %1$s [%2$i]"
msgstr "ເພີ່ມອົງປະກອບການຕິດຕັ້ງບໍ່ສຳເລັດ: %1$s [%2$i]"

#: libdnf/dnf-rpmts.cpp:312
#, c-format
msgid "Error running transaction: %s"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການດຳເນີນການທຸລະກຳ: %s"

#: libdnf/dnf-rpmts.cpp:321
msgid "Error running transaction and no problems were reported!"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການດຳເນີນການທຸລະກຳ ແລະ ບໍ່ມີການລາຍງານບັນຫາໃດໆ!"

#: libdnf/dnf-rpmts.cpp:384
msgid "Fatal error, run database recovery"
msgstr "ຂໍ້ຜິດພາດຮ້າຍແຮງ, ກະລຸນາສັ່ງກູ້ຄືນຖານຂໍ້ມູນ"

#: libdnf/dnf-rpmts.cpp:393
#, c-format
msgid "failed to find package %s"
msgstr "ຊອກຫາແພັກເກດ %s ບໍ່ພົບ"

#: libdnf/dnf-rpmts.cpp:439
#, c-format
msgid "could not add erase element %1$s(%2$i)"
msgstr "ບໍ່ສາມາດເພີ່ມອົງປະກອບການລຶບ %1$s(%2$i)"

#: libdnf/dnf-sack.cpp:261
msgid "repo_add_solv() has failed."
msgstr "repo_add_solv() ຫຼົ້ມເຫຼວ."

#: libdnf/dnf-sack.cpp:425
#, c-format
msgid "Loading extension cache %s (%d) failed: "
msgstr "ໂຫຼດແຄຊສ່ວນເສີມ %s (%d) ບໍ່ສຳເລັດ: "

#: libdnf/dnf-sack.cpp:439
#, c-format
msgid "no %1$s string for %2$s"
msgstr "ບໍ່ມີຂໍ້ຄວາມ %1$s ສຳລັບ %2$s"

#: libdnf/dnf-sack.cpp:449
#, c-format
msgid "failed to open: %s"
msgstr "ເປີດບໍ່ສຳເລັດ: %s"

#: libdnf/dnf-sack.cpp:528
#, c-format
msgid "cannot create temporary file: %s"
msgstr "ບໍ່ສາມາດສ້າງໄຟລ໌ຊົ່ວຄາວ: %s"

#: libdnf/dnf-sack.cpp:538
#, c-format
msgid "failed opening tmp file: %s"
msgstr "ເປີດໄຟລ໌ຊົ່ວຄາວ (tmp) ບໍ່ສຳເລັດ: %s"

